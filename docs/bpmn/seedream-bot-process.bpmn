      </bpmndi:BPMNShape>

      <!-- P3 -->
      <bpmndi:BPMNShape id="Shape_Start_fs" bpmnElement="Start_fs">
        <dc:Bounds x="250" y="1172" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_GW_prompt" bpmnElement="GW_prompt" isMarkerVisible="true">
        <dc:Bounds x="350" y="1165" width="50" height="50" />
      </bpmndi:BPMNShape>
