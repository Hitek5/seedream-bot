<?xml version="1.0" encoding="UTF-8"?>
<!--
  Seedream Bot — BPMN 2.0 модель работы (аудит 2026-06, переоформление подписей/раскладки).
  Открывается в bpmn.io (https://demo.bpmn.io) или Camunda Modeler.
  Короткие подписи узлов; детали — в <bpmn:documentation> (всплывают при наведении/в панели).
  Акторы вынесены в пулы/дорожки: Пользователь, Бот, fal.ai, Anthropic, Telegram API.
  Процессы: P1 текст→картинка (+петля P4 «Ещё вариант»), P2 фото→промпт,
  P3 face swap, P5 3D модель, P6 CAD (CadQuery).
-->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_seedream"
                  targetNamespace="http://seedream.bot/bpmn">

  <bpmn:collaboration id="Collab_seedream">
    <bpmn:participant id="P_user" name="Пользователь (Telegram)" />
    <bpmn:participant id="P_bot" name="Seedream Bot (grammY, long polling)" processRef="Process_bot" />
    <bpmn:participant id="P_tg" name="Telegram API (getFile)" />
    <bpmn:participant id="P_fal" name="fal.ai (Seedream / Florence-2 / birefnet / 3D)" />
    <bpmn:participant id="P_anthropic" name="Anthropic (Claude Vision / кодоген)" />
    <bpmn:messageFlow id="MF_text" name="текст промпта" sourceRef="P_user" targetRef="Start_text" />
    <bpmn:messageFlow id="MF_photo" name="фото" sourceRef="P_user" targetRef="Start_photo" />
    <bpmn:messageFlow id="MF_fs" name="«С моим фото» + фото" sourceRef="P_user" targetRef="Start_fs" />
    <bpmn:messageFlow id="MF_3d" name="«3D модель»" sourceRef="P_user" targetRef="Start_3d" />
    <bpmn:messageFlow id="MF_cad" name="/cad или кнопка" sourceRef="P_user" targetRef="Start_cad" />
    <bpmn:messageFlow id="MF_res1" name="картинка + кнопки" sourceRef="Task_result1" targetRef="P_user" />
    <bpmn:messageFlow id="MF_res2" name="промпт + кнопки" sourceRef="Task_buttons" targetRef="P_user" />
    <bpmn:messageFlow id="MF_res3" name="face swap результат" sourceRef="Task_result3" targetRef="P_user" />
    <bpmn:messageFlow id="MF_glb" name="GLB-файл" sourceRef="Task_glb" targetRef="P_user" />
    <bpmn:messageFlow id="MF_cad_files" name="STEP + STL" sourceRef="Task_send_cad" targetRef="P_user" />
    <bpmn:messageFlow id="MF_t2i" name="промпт → картинка" sourceRef="Task_t2i" targetRef="P_fal" />
    <bpmn:messageFlow id="MF_getfile" name="getFile (байты, токен не уходит)" sourceRef="Task_getfile" targetRef="P_tg" />
    <bpmn:messageFlow id="MF_upfal" name="фото → fal-URL" sourceRef="Task_upfal" targetRef="P_fal" />
    <bpmn:messageFlow id="MF_cv" name="изображение → промпт" sourceRef="Task_cv" targetRef="P_anthropic" />
    <bpmn:messageFlow id="MF_florence" name="Florence-2 caption" sourceRef="Task_florence" targetRef="P_fal" />
    <bpmn:messageFlow id="MF_edit" name="edit: face swap" sourceRef="Task_edit" targetRef="P_fal" />
    <bpmn:messageFlow id="MF_gen3d" name="birefnet → 3D" sourceRef="Task_gen3d" targetRef="P_fal" />
    <bpmn:messageFlow id="MF_cadgen" name="описание → CadQuery-код" sourceRef="Task_cad_code" targetRef="P_anthropic" />
  </bpmn:collaboration>

  <bpmn:process id="Process_bot" isExecutable="false">
    <bpmn:laneSet id="LaneSet_bot">
      <bpmn:lane id="Lane_p1" name="P1. Текст → картинка (+P4 «Ещё вариант»)">
        <bpmn:flowNodeRef>Start_text</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_empty</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_hint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_hint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_bal1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_nofunds1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_nofunds1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_progress</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_t2i</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ok1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_deduct1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_store1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_result1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_more</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_done1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_errtype</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_err_timeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_err_nsfw</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_err_rate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_err_other</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_err1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_p2" name="P2. Фото → промпт">
        <bpmn:flowNodeRef>Start_photo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_pending</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_getfile</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_upfal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_key</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_cv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_cv_ok</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_florence</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_buttons</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_p2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_p3" name="P3. Face swap">
        <bpmn:flowNodeRef>Start_fs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_prompt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_expired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_askphoto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch_photo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_hair</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_params</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch_fs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_chosen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_bal3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_nofunds3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_edit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ok3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_deduct3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_result3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_fs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_reset</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_fs_err</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_p5" name="P5. 3D модель">
        <bpmn:flowNodeRef>Start_3d</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_menu3d</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch_q</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_bal5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_nofunds5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_rembg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_gen3d</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_deduct5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_glb</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_3d</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_p6" name="P6. CAD (CadQuery)">
        <bpmn:flowNodeRef>Start_cad</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_bal6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_nofunds6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_cq</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_cq_hint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_cq_hint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_cad_vision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_cad_code</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_exec</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_files</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_cad_err</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_cad_err</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_send_cad</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_deduct6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_cleanup</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_cad</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- P1. Текст → картинка (+P4 «Ещё вариант») -->
    <bpmn:startEvent id="Start_text" name="Текст от юзера">
      <bpmn:documentation>Пользователь: присылает обычное текстовое сообщение — описание желаемой картинки. Это запускает процесс P1 (текст→картинка).</bpmn:documentation>
      <bpmn:outgoing>a1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_text" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_empty" name="Промпт пуст?">
      <bpmn:documentation>Система (Бот): проверяет, есть ли в сообщении текст промпта. Пустой ⇒ ветка подсказки; иначе ⇒ проверка баланса.</bpmn:documentation>
      <bpmn:incoming>a1</bpmn:incoming>
      <bpmn:outgoing>a2</bpmn:outgoing>
      <bpmn:outgoing>a4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_hint" name="Показать подсказку">
      <bpmn:documentation>Система (Бот): отправляет подсказку «Напиши, что хочешь увидеть» и пример промпта.</bpmn:documentation>
      <bpmn:incoming>a2</bpmn:incoming>
      <bpmn:outgoing>a3</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_hint" name="Подсказка показана">
      <bpmn:documentation>Система (Бот): конец ветки: пользователь получил инструкцию, генерация не запускалась.</bpmn:documentation>
      <bpmn:incoming>a3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_bal1" name="Баланс &lt; $0.04?">
      <bpmn:documentation>Система (Бот): сравнивает баланс пользователя с ценой генерации $0.04 (Seedream v4.5 t2i). Недостаточно ⇒ отказ; иначе ⇒ запуск. Сюда же возвращается петля «Ещё вариант» (P4).</bpmn:documentation>
      <bpmn:incoming>a4</bpmn:incoming>
      <bpmn:incoming>a15</bpmn:incoming>
      <bpmn:outgoing>a5</bpmn:outgoing>
      <bpmn:outgoing>a7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_nofunds1" name="Сообщить об отказе">
      <bpmn:documentation>Система (Бот): отвечает «Недостаточно средств» и подсказывает пополнить баланс.</bpmn:documentation>
      <bpmn:incoming>a5</bpmn:incoming>
      <bpmn:outgoing>a6</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_nofunds1" name="Отказ: нет средств">
      <bpmn:documentation>Система (Бот): конец ветки: баланс ниже $0.04, генерация не выполнялась.</bpmn:documentation>
      <bpmn:incoming>a6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_progress" name="Показать прогресс">
      <bpmn:documentation>Система (Бот): шлёт chatAction «upload_photo» и крутит таймер ~4 c для имитации прогресса (реального onQueueUpdate нет).</bpmn:documentation>
      <bpmn:incoming>a7</bpmn:incoming>
      <bpmn:outgoing>a8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="Task_t2i" name="Сгенерировать t2i">
      <bpmn:documentation>Внешний сервис (fal.ai): fal.subscribe на fal-ai/bytedance/seedream/v4.5/text-to-image: промпт → картинка. Без явного timeout, без onQueueUpdate и без ретраев.</bpmn:documentation>
      <bpmn:incoming>a8</bpmn:incoming>
      <bpmn:outgoing>a9</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_ok1" name="Генерация ОК?">
      <bpmn:documentation>Система (Бот): проверяет результат вызова fal.ai. Успех ⇒ списание и выдача; ошибка ⇒ разбор типа ошибки.</bpmn:documentation>
      <bpmn:incoming>a9</bpmn:incoming>
      <bpmn:outgoing>a10</bpmn:outgoing>
      <bpmn:outgoing>a16</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_deduct1" name="Списать $0.04">
      <bpmn:documentation>Система (Бот): deductBalance: списывает $0.04 ПОСЛЕ успешной генерации (резервирования средств нет; deductBalance=false игнорируется).</bpmn:documentation>
      <bpmn:incoming>a10</bpmn:incoming>
      <bpmn:outgoing>a11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_store1" name="Сохранить промпт">
      <bpmn:documentation>Система (Бот): promptStore: кладёт prompt и seed в in-memory Map для кнопок «Ещё вариант»/«Изменить» (seed пишется, но не переиспользуется).</bpmn:documentation>
      <bpmn:incoming>a11</bpmn:incoming>
      <bpmn:outgoing>a12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_result1" name="Отправить картинку">
      <bpmn:documentation>Система (Бот): replyWithPhoto + инлайн-кнопки: Ещё вариант / Изменить / С моим фото / Сохранить / Сначала.</bpmn:documentation>
      <bpmn:incoming>a12</bpmn:incoming>
      <bpmn:outgoing>a13</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:exclusiveGateway id="GW_more" name="Нажато «Ещё»?">
      <bpmn:documentation>Система (Бот): ждёт реакции на кнопки. «Ещё вариант» ⇒ петля P4 (повтор генерации тем же промптом); иначе ⇒ завершение.</bpmn:documentation>
      <bpmn:incoming>a13</bpmn:incoming>
      <bpmn:outgoing>a14</bpmn:outgoing>
      <bpmn:outgoing>a15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_done1" name="Картинка доставлена">
      <bpmn:documentation>Система (Бот): конец основного сценария P1: пользователь получил изображение.</bpmn:documentation>
      <bpmn:incoming>a14</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_errtype" name="Тип ошибки?">
      <bpmn:documentation>Система (Бот): getErrorMessage: классифицирует ошибку fal.ai по подстрокам (timeout / safety|nsfw|content_filter / rate|429 / прочее).</bpmn:documentation>
      <bpmn:incoming>a16</bpmn:incoming>
      <bpmn:outgoing>a17</bpmn:outgoing>
      <bpmn:outgoing>a18</bpmn:outgoing>
      <bpmn:outgoing>a19</bpmn:outgoing>
      <bpmn:outgoing>a20</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_err_timeout" name="Ответ: таймаут">
      <bpmn:documentation>Система (Бот): сообщает «fal.ai не ответил вовремя (таймаут)» и предлагает повторить.</bpmn:documentation>
      <bpmn:incoming>a17</bpmn:incoming>
      <bpmn:outgoing>a21</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Task_err_nsfw" name="Ответ: NSFW">
      <bpmn:documentation>Система (Бот): сообщает, что запрос заблокирован фильтром безопасности (safety/nsfw/content_filter).</bpmn:documentation>
      <bpmn:incoming>a18</bpmn:incoming>
      <bpmn:outgoing>a22</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Task_err_rate" name="Ответ: rate limit">
      <bpmn:documentation>Система (Бот): сообщает «Слишком много запросов» (rate limit / HTTP 429), просит подождать.</bpmn:documentation>
      <bpmn:incoming>a19</bpmn:incoming>
      <bpmn:outgoing>a23</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Task_err_other" name="Ответ: иная ошибка">
      <bpmn:documentation>Система (Бот): показывает текст прочей ошибки fal.ai как есть.</bpmn:documentation>
      <bpmn:incoming>a20</bpmn:incoming>
      <bpmn:outgoing>a24</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_err1" name="Ошибка показана">
      <bpmn:documentation>Система (Бот): конец ветки ошибок: пользователь уведомлён, списания не было.</bpmn:documentation>
      <bpmn:incoming>a21</bpmn:incoming>
      <bpmn:incoming>a22</bpmn:incoming>
      <bpmn:incoming>a23</bpmn:incoming>
      <bpmn:incoming>a24</bpmn:incoming>
    </bpmn:endEvent>

    <!-- P2. Фото → промпт -->
    <bpmn:startEvent id="Start_photo" name="Фото от юзера">
      <bpmn:documentation>Пользователь: присылает фотографию. Запускает P2 (фото→промпт) либо передаёт фото в P3, если идёт face swap.</bpmn:documentation>
      <bpmn:outgoing>b1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_photo" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_pending" name="Ждём фото FS?">
      <bpmn:documentation>Система (Бот): проверяет флаг pendingFaceSwap. Активен ⇒ это фото для face swap (P3); иначе ⇒ анализ фото в P2.</bpmn:documentation>
      <bpmn:incoming>b1</bpmn:incoming>
      <bpmn:outgoing>b2</bpmn:outgoing>
      <bpmn:outgoing>b3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_getfile" name="Скачать байты">
      <bpmn:documentation>Внешний сервис (Telegram API): getFile + скачивание байтов фото. URL вида api.telegram.org/file/bot&lt;TOKEN&gt;/… наружу не передаётся (только байты).</bpmn:documentation>
      <bpmn:incoming>b3</bpmn:incoming>
      <bpmn:outgoing>b4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_upfal" name="Загрузить в fal">
      <bpmn:documentation>Внешний сервис (fal.ai): fal.storage.upload: кладёт байты фото и получает fal-URL без токена для дальнейшего анализа/редактирования.</bpmn:documentation>
      <bpmn:incoming>b4</bpmn:incoming>
      <bpmn:outgoing>b5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_key" name="Есть API-ключ?">
      <bpmn:documentation>Система (Бот): проверяет ANTHROPIC_API_KEY. Задан ⇒ Claude Vision; не задан ⇒ сразу Florence-2.</bpmn:documentation>
      <bpmn:incoming>b5</bpmn:incoming>
      <bpmn:outgoing>b6</bpmn:outgoing>
      <bpmn:outgoing>b10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_cv" name="Claude Vision">
      <bpmn:documentation>Внешний сервис (Anthropic): Claude Vision (claude-sonnet-4) по изображению (base64) формирует Seedream-промпт. Анализ бесплатный и без лимитов.</bpmn:documentation>
      <bpmn:incoming>b6</bpmn:incoming>
      <bpmn:outgoing>b7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_cv_ok" name="Claude ОК?">
      <bpmn:documentation>Система (Бот): проверяет ответ Claude. Успех ⇒ выдача промпта; ошибка ⇒ fallback Florence-2.</bpmn:documentation>
      <bpmn:incoming>b7</bpmn:incoming>
      <bpmn:outgoing>b8</bpmn:outgoing>
      <bpmn:outgoing>b9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_florence" name="Florence-2 caption">
      <bpmn:documentation>Внешний сервис (fal.ai): fallback: Florence-2 на fal.ai строит caption + добавляет теги качества, когда Claude недоступен или упал.</bpmn:documentation>
      <bpmn:incoming>b9</bpmn:incoming>
      <bpmn:incoming>b10</bpmn:incoming>
      <bpmn:outgoing>b11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Task_buttons" name="Отправить промпт">
      <bpmn:documentation>Система (Бот): шлёт готовый промпт и 7 инлайн-кнопок действий (сгенерировать, изменить, с моим фото и т.д.).</bpmn:documentation>
      <bpmn:incoming>b8</bpmn:incoming>
      <bpmn:incoming>b11</bpmn:incoming>
      <bpmn:outgoing>b12</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_p2" name="Промпт доставлен">
      <bpmn:documentation>Система (Бот): конец P2: пользователь получил промпт по фото.</bpmn:documentation>
      <bpmn:incoming>b12</bpmn:incoming>
    </bpmn:endEvent>

    <!-- P3. Face swap -->
    <bpmn:startEvent id="Start_fs" name="Кнопка «С фото»">
      <bpmn:documentation>Пользователь: нажимает инлайн-кнопку «С моим фото» под картинкой. Запускает P3 (face swap).</bpmn:documentation>
      <bpmn:outgoing>c1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_fs" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_prompt" name="Промпт найден?">
      <bpmn:documentation>Система (Бот): ищет исходный промпт (promptStore Map → fallback caption). Не найден ⇒ сессия истекла; найден ⇒ запрос фото.</bpmn:documentation>
      <bpmn:incoming>c1</bpmn:incoming>
      <bpmn:outgoing>c2</bpmn:outgoing>
      <bpmn:outgoing>c3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_expired" name="Сессия истекла">
      <bpmn:documentation>Система (Бот): конец ветки: промпт не найден (Map очищена/рестарт), просит начать заново.</bpmn:documentation>
      <bpmn:incoming>c2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Task_askphoto" name="Запросить фото">
      <bpmn:documentation>Система (Бот): просит прислать фото лица пользователя для подстановки в сцену.</bpmn:documentation>
      <bpmn:incoming>c3</bpmn:incoming>
      <bpmn:outgoing>c4</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="Catch_photo" name="Фото получено">
      <bpmn:documentation>Пользователь: присылает своё фото; бот ловит его (сюда же приходит фото из P2 при активном pendingFaceSwap).</bpmn:documentation>
      <bpmn:incoming>b2</bpmn:incoming>
      <bpmn:incoming>c4</bpmn:incoming>
      <bpmn:outgoing>c5</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_userphoto" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Task_hair" name="Цвет волос">
      <bpmn:documentation>Внешний сервис (fal.ai): Florence-2 определяет цвет волос на фото для уточнения промпта. Ошибки молча игнорируются.</bpmn:documentation>
      <bpmn:incoming>c5</bpmn:incoming>
      <bpmn:outgoing>c6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Task_params" name="Меню параметров">
      <bpmn:documentation>Система (Бот): показывает клавиатуру параметров: рост / фигура / причёска.</bpmn:documentation>
      <bpmn:incoming>c6</bpmn:incoming>
      <bpmn:incoming>c9</bpmn:incoming>
      <bpmn:outgoing>c7</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="Catch_fs" name="Выбор fs_*">
      <bpmn:documentation>Пользователь: нажимает кнопки параметров (callback fs_*). Бот накапливает выбор.</bpmn:documentation>
      <bpmn:incoming>c7</bpmn:incoming>
      <bpmn:outgoing>c8</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_fsparam" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="GW_chosen" name="Рост+фигура?">
      <bpmn:documentation>Система (Бот): проверяет, выбраны ли рост И фигура. Нет ⇒ обновить клавиатуру и ждать; да ⇒ проверка баланса.</bpmn:documentation>
      <bpmn:incoming>c8</bpmn:incoming>
      <bpmn:outgoing>c9</bpmn:outgoing>
      <bpmn:outgoing>c10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_bal3" name="Баланс &lt; $0.08?">
      <bpmn:documentation>Система (Бот): сравнивает баланс с ценой face swap $0.08 (Seedream v4.5 edit). Недостаточно ⇒ отказ; иначе ⇒ запуск.</bpmn:documentation>
      <bpmn:incoming>c10</bpmn:incoming>
      <bpmn:outgoing>c11</bpmn:outgoing>
      <bpmn:outgoing>c12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_nofunds3" name="Отказ: нет средств">
      <bpmn:documentation>Система (Бот): конец ветки: баланс ниже $0.08, face swap не выполнялся.</bpmn:documentation>
      <bpmn:incoming>c11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_edit" name="Seedream edit">
      <bpmn:documentation>Внешний сервис (fal.ai): fal.subscribe на fal-ai/bytedance/seedream/v4.5/edit: подставляет лицо (фото из fal.storage) в сцену по промпту.</bpmn:documentation>
      <bpmn:incoming>c12</bpmn:incoming>
      <bpmn:outgoing>c13</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_ok3" name="Успех?">
      <bpmn:documentation>Система (Бот): проверяет результат edit. Успех ⇒ списание и выдача; ошибка ⇒ сброс состояния.</bpmn:documentation>
      <bpmn:incoming>c13</bpmn:incoming>
      <bpmn:outgoing>c14</bpmn:outgoing>
      <bpmn:outgoing>c17</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_deduct3" name="Списать $0.08">
      <bpmn:documentation>Система (Бот): deductBalance: списывает $0.08 после успешного face swap.</bpmn:documentation>
      <bpmn:incoming>c14</bpmn:incoming>
      <bpmn:outgoing>c15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_result3" name="Отправить фото">
      <bpmn:documentation>Система (Бот): отправляет результат face swap и инлайн-кнопки дальнейших действий.</bpmn:documentation>
      <bpmn:incoming>c15</bpmn:incoming>
      <bpmn:outgoing>c16</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_fs" name="Face swap готов">
      <bpmn:documentation>Система (Бот): конец основного сценария P3: пользователь получил изображение с подменённым лицом.</bpmn:documentation>
      <bpmn:incoming>c16</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_reset" name="Сбросить FS">
      <bpmn:documentation>Система (Бот): сбрасывает pendingFaceSwap и связанное состояние после ошибки.</bpmn:documentation>
      <bpmn:incoming>c17</bpmn:incoming>
      <bpmn:outgoing>c18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_fs_err" name="Ошибка показана">
      <bpmn:documentation>Система (Бот): конец ветки ошибок P3: пользователь уведомлён, списания не было.</bpmn:documentation>
      <bpmn:incoming>c18</bpmn:incoming>
    </bpmn:endEvent>

    <!-- P5. 3D модель -->
    <bpmn:startEvent id="Start_3d" name="Кнопка «3D»">
      <bpmn:documentation>Пользователь: нажимает инлайн-кнопку «3D модель». Запускает P5 (3D).</bpmn:documentation>
      <bpmn:outgoing>d1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_3d" />
    </bpmn:startEvent>
    <bpmn:sendTask id="Task_menu3d" name="Меню качества">
      <bpmn:documentation>Система (Бот): показывает выбор качества: fast / standard / high (разная модель и цена).</bpmn:documentation>
      <bpmn:incoming>d1</bpmn:incoming>
      <bpmn:outgoing>d2</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="Catch_q" name="Выбор качества">
      <bpmn:documentation>Пользователь: выбирает качество (callback threed:*). Бот фиксирует пресет.</bpmn:documentation>
      <bpmn:incoming>d2</bpmn:incoming>
      <bpmn:outgoing>d3</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_q" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="GW_bal5" name="Баланс мал?">
      <bpmn:documentation>Система (Бот): сравнивает баланс с ценой выбранного пресета ($0.05–0.10). Недостаточно ⇒ отказ; иначе ⇒ генерация.</bpmn:documentation>
      <bpmn:incoming>d3</bpmn:incoming>
      <bpmn:outgoing>d4</bpmn:outgoing>
      <bpmn:outgoing>d5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_nofunds5" name="Отказ: нет средств">
      <bpmn:documentation>Система (Бот): конец ветки: баланс ниже цены 3D-пресета, генерация не выполнялась.</bpmn:documentation>
      <bpmn:incoming>d4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_rembg" name="Удалить фон">
      <bpmn:documentation>Внешний сервис (fal.ai): birefnet удаляет фон с исходного изображения перед 3D-реконструкцией.</bpmn:documentation>
      <bpmn:incoming>d5</bpmn:incoming>
      <bpmn:outgoing>d6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_gen3d" name="Сгенерировать 3D">
      <bpmn:documentation>Внешний сервис (fal.ai): 3D-реконструкция: TripoSR / Hunyuan3D / Trellis в зависимости от выбранного качества.</bpmn:documentation>
      <bpmn:incoming>d6</bpmn:incoming>
      <bpmn:outgoing>d7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="Task_deduct5" name="Списать $0.05–0.10">
      <bpmn:documentation>Система (Бот): deductBalance: списывает стоимость выбранного 3D-пресета ($0.05–0.10) после генерации.</bpmn:documentation>
      <bpmn:incoming>d7</bpmn:incoming>
      <bpmn:outgoing>d8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_glb" name="Отправить GLB">
      <bpmn:documentation>Система (Бот): отправляет готовый GLB-файл 3D-модели документом.</bpmn:documentation>
      <bpmn:incoming>d8</bpmn:incoming>
      <bpmn:outgoing>d9</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_3d" name="3D доставлена">
      <bpmn:documentation>Система (Бот): конец P5: пользователь получил 3D-модель (GLB).</bpmn:documentation>
      <bpmn:incoming>d9</bpmn:incoming>
    </bpmn:endEvent>

    <!-- P6. CAD (CadQuery) -->
    <bpmn:startEvent id="Start_cad" name="/cad или кнопка">
      <bpmn:documentation>Пользователь: вызывает /cad с описанием либо нажимает кнопку «CAD модель». Запускает P6 (CAD).</bpmn:documentation>
      <bpmn:outgoing>e1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_cad" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_bal6" name="Баланс &lt; $0.02?">
      <bpmn:documentation>Система (Бот): сравнивает баланс с ценой CAD $0.02. Недостаточно ⇒ отказ; иначе ⇒ проверка окружения.</bpmn:documentation>
      <bpmn:incoming>e1</bpmn:incoming>
      <bpmn:outgoing>e2</bpmn:outgoing>
      <bpmn:outgoing>e3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_nofunds6" name="Отказ: нет средств">
      <bpmn:documentation>Система (Бот): конец ветки: баланс ниже $0.02, CAD не выполнялся.</bpmn:documentation>
      <bpmn:incoming>e2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_cq" name="CadQuery есть?">
      <bpmn:documentation>Система (Бот): проверяет CADQUERY_PYTHON (установлен ли CadQuery). Нет ⇒ подсказка; да ⇒ генерация модели.</bpmn:documentation>
      <bpmn:incoming>e3</bpmn:incoming>
      <bpmn:outgoing>e4</bpmn:outgoing>
      <bpmn:outgoing>e6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_cq_hint" name="Подсказка install">
      <bpmn:documentation>Система (Бот): подсказывает установить пакет: pip install cadquery.</bpmn:documentation>
      <bpmn:incoming>e4</bpmn:incoming>
      <bpmn:outgoing>e5</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_cq_hint" name="CAD недоступен">
      <bpmn:documentation>Система (Бот): конец ветки: окружение CadQuery не настроено.</bpmn:documentation>
      <bpmn:incoming>e5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_cad_vision" name="Описать деталь">
      <bpmn:documentation>Внешний сервис (Anthropic): Claude Vision описывает деталь по фото; для текстового /cad берётся переданное описание.</bpmn:documentation>
      <bpmn:incoming>e6</bpmn:incoming>
      <bpmn:outgoing>e7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_cad_code" name="Сгенерить код">
      <bpmn:documentation>Внешний сервис (Anthropic): Claude генерирует Python-код CadQuery по описанию детали.</bpmn:documentation>
      <bpmn:incoming>e7</bpmn:incoming>
      <bpmn:outgoing>e8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Task_exec" name="Выполнить код">
      <bpmn:documentation>Система (Бот): execFile CADQUERY_PYTHON во временном каталоге, таймаут 60 c. Песочницы нет — управляемое пользователем исполнение кода.</bpmn:documentation>
      <bpmn:incoming>e8</bpmn:incoming>
      <bpmn:outgoing>e9</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="GW_files" name="STEP/STL есть?">
      <bpmn:documentation>Система (Бот): проверяет, созданы ли файлы STEP и STL. Нет ⇒ ошибка; да ⇒ отправка.</bpmn:documentation>
      <bpmn:incoming>e9</bpmn:incoming>
      <bpmn:outgoing>e10</bpmn:outgoing>
      <bpmn:outgoing>e12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_cad_err" name="Ответ об ошибке">
      <bpmn:documentation>Система (Бот): сообщает об ошибке генерации/исполнения CadQuery-кода.</bpmn:documentation>
      <bpmn:incoming>e10</bpmn:incoming>
      <bpmn:outgoing>e11</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_cad_err" name="Ошибка показана">
      <bpmn:documentation>Система (Бот): конец ветки ошибок P6: файлы не получены, списания не было.</bpmn:documentation>
      <bpmn:incoming>e11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Task_send_cad" name="Отправить файлы">
      <bpmn:documentation>Система (Бот): отправляет результат: файлы STEP + STL документами.</bpmn:documentation>
      <bpmn:incoming>e12</bpmn:incoming>
      <bpmn:outgoing>e13</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:task id="Task_deduct6" name="Списать $0.02">
      <bpmn:documentation>Система (Бот): deductBalance: списывает $0.02 после успешной генерации CAD.</bpmn:documentation>
      <bpmn:incoming>e13</bpmn:incoming>
      <bpmn:outgoing>e14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_cleanup" name="Очистить tmp">
      <bpmn:documentation>Система (Бот): rmSync: удаляет временный каталог с артефактами CadQuery.</bpmn:documentation>
      <bpmn:incoming>e14</bpmn:incoming>
      <bpmn:outgoing>e15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_cad" name="CAD доставлена">
      <bpmn:documentation>Система (Бот): конец P6: пользователь получил STEP + STL.</bpmn:documentation>
      <bpmn:incoming>e15</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Потоки -->
    <bpmn:sequenceFlow id="a1" sourceRef="Start_text" targetRef="GW_empty" />
    <bpmn:sequenceFlow id="a2" name="пусто" sourceRef="GW_empty" targetRef="Task_hint" />
    <bpmn:sequenceFlow id="a3" sourceRef="Task_hint" targetRef="End_hint" />
    <bpmn:sequenceFlow id="a4" name="есть текст" sourceRef="GW_empty" targetRef="GW_bal1" />
    <bpmn:sequenceFlow id="a5" name="баланс &lt; $0.04" sourceRef="GW_bal1" targetRef="Task_nofunds1" />
    <bpmn:sequenceFlow id="a6" sourceRef="Task_nofunds1" targetRef="End_nofunds1" />
    <bpmn:sequenceFlow id="a7" name="достаточно" sourceRef="GW_bal1" targetRef="Task_progress" />
    <bpmn:sequenceFlow id="a8" sourceRef="Task_progress" targetRef="Task_t2i" />
    <bpmn:sequenceFlow id="a9" sourceRef="Task_t2i" targetRef="GW_ok1" />
    <bpmn:sequenceFlow id="a10" name="успех" sourceRef="GW_ok1" targetRef="Task_deduct1" />
    <bpmn:sequenceFlow id="a11" sourceRef="Task_deduct1" targetRef="Task_store1" />
    <bpmn:sequenceFlow id="a12" sourceRef="Task_store1" targetRef="Task_result1" />
    <bpmn:sequenceFlow id="a13" sourceRef="Task_result1" targetRef="GW_more" />
    <bpmn:sequenceFlow id="a14" name="нет" sourceRef="GW_more" targetRef="End_done1" />
    <bpmn:sequenceFlow id="a15" name="«Ещё вариант» (P4)" sourceRef="GW_more" targetRef="GW_bal1" />
    <bpmn:sequenceFlow id="a16" name="ошибка" sourceRef="GW_ok1" targetRef="GW_errtype" />
    <bpmn:sequenceFlow id="a17" name="timeout" sourceRef="GW_errtype" targetRef="Task_err_timeout" />
    <bpmn:sequenceFlow id="a18" name="NSFW" sourceRef="GW_errtype" targetRef="Task_err_nsfw" />
    <bpmn:sequenceFlow id="a19" name="rate limit" sourceRef="GW_errtype" targetRef="Task_err_rate" />
    <bpmn:sequenceFlow id="a20" name="прочее" sourceRef="GW_errtype" targetRef="Task_err_other" />
    <bpmn:sequenceFlow id="a21" sourceRef="Task_err_timeout" targetRef="End_err1" />
    <bpmn:sequenceFlow id="a22" sourceRef="Task_err_nsfw" targetRef="End_err1" />
    <bpmn:sequenceFlow id="a23" sourceRef="Task_err_rate" targetRef="End_err1" />
    <bpmn:sequenceFlow id="a24" sourceRef="Task_err_other" targetRef="End_err1" />
    <bpmn:sequenceFlow id="b1" sourceRef="Start_photo" targetRef="GW_pending" />
    <bpmn:sequenceFlow id="b2" name="да → face swap (P3)" sourceRef="GW_pending" targetRef="Catch_photo" />
    <bpmn:sequenceFlow id="b3" name="нет" sourceRef="GW_pending" targetRef="Task_getfile" />
    <bpmn:sequenceFlow id="b4" sourceRef="Task_getfile" targetRef="Task_upfal" />
    <bpmn:sequenceFlow id="b5" sourceRef="Task_upfal" targetRef="GW_key" />
    <bpmn:sequenceFlow id="b6" name="есть ключ" sourceRef="GW_key" targetRef="Task_cv" />
    <bpmn:sequenceFlow id="b7" sourceRef="Task_cv" targetRef="GW_cv_ok" />
    <bpmn:sequenceFlow id="b8" name="успех" sourceRef="GW_cv_ok" targetRef="Task_buttons" />
    <bpmn:sequenceFlow id="b9" name="ошибка → fallback" sourceRef="GW_cv_ok" targetRef="Task_florence" />
    <bpmn:sequenceFlow id="b10" name="нет ключа" sourceRef="GW_key" targetRef="Task_florence" />
    <bpmn:sequenceFlow id="b11" sourceRef="Task_florence" targetRef="Task_buttons" />
    <bpmn:sequenceFlow id="b12" sourceRef="Task_buttons" targetRef="End_p2" />
    <bpmn:sequenceFlow id="c1" sourceRef="Start_fs" targetRef="GW_prompt" />
    <bpmn:sequenceFlow id="c2" name="нет — истёк" sourceRef="GW_prompt" targetRef="End_expired" />
