<?xml version="1.0" encoding="UTF-8"?>
<!--
  Seedream Bot — BPMN 2.0 модель работы (аудит 2026-06).
  Открывается в bpmn.io (https://demo.bpmn.io) или Camunda Modeler.
  Процессы: P1 текст→картинка (+петля P4 «Ещё вариант»), P2 фото→промпт,
  P3 face swap, P5 3D модель, P6 CAD (CadQuery).
-->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_seedream"
                  targetNamespace="http://seedream.bot/bpmn">

  <bpmn:collaboration id="Collab_seedream">
    <bpmn:participant id="P_user" name="Пользователь (Telegram)" />
    <bpmn:participant id="P_bot" name="Seedream Bot (grammY, long polling)" processRef="Process_bot" />
    <bpmn:participant id="P_tg" name="Telegram API (getFile)" />
    <bpmn:participant id="P_fal" name="fal.ai (Seedream / Florence-2 / birefnet / 3D)" />
    <bpmn:participant id="P_anthropic" name="Anthropic (Claude Vision / кодоген)" />

    <bpmn:messageFlow id="MF_text" name="текст промпта" sourceRef="P_user" targetRef="Start_text" />
    <bpmn:messageFlow id="MF_photo" name="фото" sourceRef="P_user" targetRef="Start_photo" />
    <bpmn:messageFlow id="MF_fs" name="кнопка «С моим фото» + фото" sourceRef="P_user" targetRef="Start_fs" />
    <bpmn:messageFlow id="MF_3d" name="кнопка «3D модель»" sourceRef="P_user" targetRef="Start_3d" />
    <bpmn:messageFlow id="MF_cad" name="/cad описание или кнопка" sourceRef="P_user" targetRef="Start_cad" />
    <bpmn:messageFlow id="MF_res1" name="картинка + кнопки" sourceRef="Task_result1" targetRef="P_user" />
    <bpmn:messageFlow id="MF_res2" name="промпт + кнопки" sourceRef="Task_buttons" targetRef="P_user" />
    <bpmn:messageFlow id="MF_res3" name="face swap результат" sourceRef="Task_result3" targetRef="P_user" />
    <bpmn:messageFlow id="MF_glb" name="GLB-файл" sourceRef="Task_glb" targetRef="P_user" />
    <bpmn:messageFlow id="MF_cad_files" name="STEP + STL" sourceRef="Task_send_cad" targetRef="P_user" />
    <bpmn:messageFlow id="MF_t2i" name="t2i: промпт → картинка" sourceRef="Task_t2i" targetRef="P_fal" />
    <bpmn:messageFlow id="MF_getfile" name="getFile + скачивание байтов (URL с токеном не уходит наружу)" sourceRef="Task_getfile" targetRef="P_tg" />
    <bpmn:messageFlow id="MF_upfal" name="загрузка фото → fal-URL" sourceRef="Task_upfal" targetRef="P_fal" />
    <bpmn:messageFlow id="MF_cv" name="изображение (base64) → промпт" sourceRef="Task_cv" targetRef="P_anthropic" />
    <bpmn:messageFlow id="MF_florence" name="Florence-2 caption" sourceRef="Task_florence" targetRef="P_fal" />
    <bpmn:messageFlow id="MF_edit" name="edit: face swap" sourceRef="Task_edit" targetRef="P_fal" />
    <bpmn:messageFlow id="MF_gen3d" name="birefnet → 3D-генерация" sourceRef="Task_gen3d" targetRef="P_fal" />
    <bpmn:messageFlow id="MF_cadgen" name="описание → CadQuery-код" sourceRef="Task_cad_code" targetRef="P_anthropic" />
  </bpmn:collaboration>

  <bpmn:process id="Process_bot" isExecutable="false">
    <bpmn:laneSet id="LaneSet_bot">
      <bpmn:lane id="Lane_p1" name="P1. Текст → картинка (+P4 «Ещё вариант»)">
        <bpmn:flowNodeRef>Start_text</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_empty</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_hint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_hint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_bal1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_nofunds1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_nofunds1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_progress</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_t2i</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ok1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_deduct1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_store1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_result1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_more</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_done1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_errtype</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_err_timeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_err_nsfw</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_err_rate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_err_other</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_err1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_p2" name="P2. Фото → промпт">
        <bpmn:flowNodeRef>Start_photo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_pending</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_getfile</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_upfal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_key</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_cv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_cv_ok</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_florence</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_buttons</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_p2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_p3" name="P3. Face swap">
        <bpmn:flowNodeRef>Start_fs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_prompt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_expired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_askphoto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch_photo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_hair</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_params</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch_fs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_chosen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_bal3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_nofunds3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_edit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ok3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_deduct3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_result3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_fs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_reset</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_fs_err</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_p5" name="P5. 3D модель">
        <bpmn:flowNodeRef>Start_3d</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_menu3d</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch_q</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_bal5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_nofunds5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_rembg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_gen3d</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_deduct5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_glb</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_3d</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_p6" name="P6. CAD (CadQuery)">
        <bpmn:flowNodeRef>Start_cad</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_bal6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_nofunds6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_cq</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_cq_hint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_cq_hint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_cad_vision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_cad_code</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_exec</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_files</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_cad_err</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_cad_err</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_send_cad</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_deduct6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_cleanup</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_cad</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- P1. Текст → картинка -->
    <bpmn:startEvent id="Start_text" name="Текстовое сообщение">
      <bpmn:outgoing>a1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_text" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_empty" name="Промпт пуст?">
      <bpmn:incoming>a1</bpmn:incoming>
      <bpmn:outgoing>a2</bpmn:outgoing>
      <bpmn:outgoing>a4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_hint" name="Подсказка «Напиши что хочешь увидеть»">
      <bpmn:incoming>a2</bpmn:incoming>
      <bpmn:outgoing>a3</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_hint" name="Подсказка показана">
      <bpmn:incoming>a3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_bal1" name="Баланс ≥ $0.04?">
      <bpmn:incoming>a4</bpmn:incoming>
      <bpmn:incoming>a15</bpmn:incoming>
      <bpmn:outgoing>a5</bpmn:outgoing>
      <bpmn:outgoing>a7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_nofunds1" name="Ответ «Недостаточно средств»">
      <bpmn:incoming>a5</bpmn:incoming>
      <bpmn:outgoing>a6</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_nofunds1" name="Отказ: нет средств">
      <bpmn:incoming>a6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_progress" name="chatAction + таймер 4 c (имитация прогресса)">
      <bpmn:incoming>a7</bpmn:incoming>
      <bpmn:outgoing>a8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="Task_t2i" name="fal.subscribe: Seedream v4.5 t2i (без таймаута и ретраев)">
      <bpmn:incoming>a8</bpmn:incoming>
      <bpmn:outgoing>a9</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_ok1" name="Генерация успешна?">
      <bpmn:incoming>a9</bpmn:incoming>
      <bpmn:outgoing>a10</bpmn:outgoing>
      <bpmn:outgoing>a16</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_deduct1" name="deductBalance $0.04 (после генерации)">
      <bpmn:incoming>a10</bpmn:incoming>
      <bpmn:outgoing>a11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_store1" name="promptStore: prompt + seed (in-memory)">
      <bpmn:incoming>a11</bpmn:incoming>
      <bpmn:outgoing>a12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_result1" name="replyWithPhoto + кнопки (Ещё вариант / Изменить / С моим фото / Сохранить / Сначала)">
      <bpmn:incoming>a12</bpmn:incoming>
      <bpmn:outgoing>a13</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:exclusiveGateway id="GW_more" name="Нажата «Ещё вариант»?">
      <bpmn:incoming>a13</bpmn:incoming>
      <bpmn:outgoing>a14</bpmn:outgoing>
      <bpmn:outgoing>a15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_done1" name="Картинка доставлена">
      <bpmn:incoming>a14</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_errtype" name="Тип ошибки? (getErrorMessage)">
      <bpmn:incoming>a16</bpmn:incoming>
      <bpmn:outgoing>a17</bpmn:outgoing>
      <bpmn:outgoing>a18</bpmn:outgoing>
      <bpmn:outgoing>a19</bpmn:outgoing>
      <bpmn:outgoing>a20</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_err_timeout" name="Ответ «Таймаут fal.ai»">
      <bpmn:incoming>a17</bpmn:incoming>
      <bpmn:outgoing>a21</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Task_err_nsfw" name="Ответ «Заблокировано фильтром безопасности»">
      <bpmn:incoming>a18</bpmn:incoming>
      <bpmn:outgoing>a22</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Task_err_rate" name="Ответ «Слишком много запросов»">
      <bpmn:incoming>a19</bpmn:incoming>
      <bpmn:outgoing>a23</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Task_err_other" name="Ответ с текстом ошибки">
      <bpmn:incoming>a20</bpmn:incoming>
      <bpmn:outgoing>a24</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_err1" name="Ошибка показана">
      <bpmn:incoming>a21</bpmn:incoming>
      <bpmn:incoming>a22</bpmn:incoming>
      <bpmn:incoming>a23</bpmn:incoming>
      <bpmn:incoming>a24</bpmn:incoming>
    </bpmn:endEvent>

    <!-- P2. Фото → промпт -->
    <bpmn:startEvent id="Start_photo" name="Фото получено">
      <bpmn:outgoing>b1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_photo" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_pending" name="pendingFaceSwap активен?">
      <bpmn:incoming>b1</bpmn:incoming>
      <bpmn:outgoing>b2</bpmn:outgoing>
      <bpmn:outgoing>b3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_getfile" name="getFile: скачать байты фото">
      <bpmn:incoming>b3</bpmn:incoming>
      <bpmn:outgoing>b4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_upfal" name="Загрузить в fal.storage (fal-URL без токена)">
      <bpmn:incoming>b4</bpmn:incoming>
      <bpmn:outgoing>b5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_key" name="ANTHROPIC_API_KEY задан?">
      <bpmn:incoming>b5</bpmn:incoming>
      <bpmn:outgoing>b6</bpmn:outgoing>
      <bpmn:outgoing>b10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_cv" name="Claude Vision: Seedream-промпт по фото">
      <bpmn:incoming>b6</bpmn:incoming>
      <bpmn:outgoing>b7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_cv_ok" name="Claude успешен?">
      <bpmn:incoming>b7</bpmn:incoming>
      <bpmn:outgoing>b8</bpmn:outgoing>
      <bpmn:outgoing>b9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_florence" name="Fallback: Florence-2 caption + теги качества">
      <bpmn:incoming>b9</bpmn:incoming>
      <bpmn:incoming>b10</bpmn:incoming>
      <bpmn:outgoing>b11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Task_buttons" name="Промпт + 7 кнопок действий">
      <bpmn:incoming>b8</bpmn:incoming>
      <bpmn:incoming>b11</bpmn:incoming>
      <bpmn:outgoing>b12</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_p2" name="Промпт доставлен">
      <bpmn:incoming>b12</bpmn:incoming>
    </bpmn:endEvent>

    <!-- P3. Face swap -->
    <bpmn:startEvent id="Start_fs" name="Callback «С моим фото»">
      <bpmn:outgoing>c1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_fs" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_prompt" name="Промпт найден? (Map / caption)">
      <bpmn:incoming>c1</bpmn:incoming>
      <bpmn:outgoing>c2</bpmn:outgoing>
      <bpmn:outgoing>c3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_expired" name="Сессия истекла">
      <bpmn:incoming>c2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Task_askphoto" name="Запросить фото пользователя">
      <bpmn:incoming>c3</bpmn:incoming>
      <bpmn:outgoing>c4</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="Catch_photo" name="Фото пользователя получено">
      <bpmn:incoming>c4</bpmn:incoming>
      <bpmn:incoming>b2</bpmn:incoming>
      <bpmn:outgoing>c5</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_userphoto" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Task_hair" name="Florence-2: определить цвет волос (ошибки глотаются)">
      <bpmn:incoming>c5</bpmn:incoming>
      <bpmn:outgoing>c6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Task_params" name="Клавиатура параметров (рост / фигура / причёска)">
      <bpmn:incoming>c6</bpmn:incoming>
      <bpmn:incoming>c9</bpmn:incoming>
      <bpmn:outgoing>c7</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="Catch_fs" name="Callback fs_*">
      <bpmn:incoming>c7</bpmn:incoming>
      <bpmn:outgoing>c8</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_fsparam" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="GW_chosen" name="Рост и фигура выбраны?">
      <bpmn:incoming>c8</bpmn:incoming>
      <bpmn:outgoing>c9</bpmn:outgoing>
      <bpmn:outgoing>c10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_bal3" name="Баланс ≥ $0.08?">
      <bpmn:incoming>c10</bpmn:incoming>
      <bpmn:outgoing>c11</bpmn:outgoing>
      <bpmn:outgoing>c12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_nofunds3" name="Отказ: нет средств">
      <bpmn:incoming>c11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_edit" name="fal.subscribe: Seedream v4.5 edit (фото из fal.storage)">
      <bpmn:incoming>c12</bpmn:incoming>
      <bpmn:outgoing>c13</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_ok3" name="Успех?">
      <bpmn:incoming>c13</bpmn:incoming>
      <bpmn:outgoing>c14</bpmn:outgoing>
      <bpmn:outgoing>c17</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_deduct3" name="deductBalance $0.08">
      <bpmn:incoming>c14</bpmn:incoming>
      <bpmn:outgoing>c15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_result3" name="Фото-результат + кнопки">
      <bpmn:incoming>c15</bpmn:incoming>
      <bpmn:outgoing>c16</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_fs" name="Face swap готов">
      <bpmn:incoming>c16</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_reset" name="Сброс pendingFaceSwap">
      <bpmn:incoming>c17</bpmn:incoming>
      <bpmn:outgoing>c18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_fs_err" name="Ошибка показана">
      <bpmn:incoming>c18</bpmn:incoming>
    </bpmn:endEvent>

    <!-- P5. 3D модель -->
    <bpmn:startEvent id="Start_3d" name="Callback «3D модель»">
      <bpmn:outgoing>d1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_3d" />
    </bpmn:startEvent>
    <bpmn:sendTask id="Task_menu3d" name="Меню качества (fast / standard / high)">
      <bpmn:incoming>d1</bpmn:incoming>
      <bpmn:outgoing>d2</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="Catch_q" name="Callback threed:качество">
      <bpmn:incoming>d2</bpmn:incoming>
      <bpmn:outgoing>d3</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_q" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="GW_bal5" name="Баланс ≥ $0.05–0.10?">
      <bpmn:incoming>d3</bpmn:incoming>
      <bpmn:outgoing>d4</bpmn:outgoing>
      <bpmn:outgoing>d5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_nofunds5" name="Отказ: нет средств">
      <bpmn:incoming>d4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_rembg" name="birefnet: удалить фон">
      <bpmn:incoming>d5</bpmn:incoming>
      <bpmn:outgoing>d6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_gen3d" name="3D: TripoSR / Hunyuan3D / Trellis">
      <bpmn:incoming>d6</bpmn:incoming>
      <bpmn:outgoing>d7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="Task_deduct5" name="deductBalance $0.05–0.10">
      <bpmn:incoming>d7</bpmn:incoming>
      <bpmn:outgoing>d8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_glb" name="Отправить GLB-файл">
      <bpmn:incoming>d8</bpmn:incoming>
      <bpmn:outgoing>d9</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_3d" name="3D модель доставлена">
      <bpmn:incoming>d9</bpmn:incoming>
    </bpmn:endEvent>

    <!-- P6. CAD (CadQuery) -->
    <bpmn:startEvent id="Start_cad" name="/cad или callback «CAD модель»">
      <bpmn:outgoing>e1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_cad" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_bal6" name="Баланс ≥ $0.02?">
      <bpmn:incoming>e1</bpmn:incoming>
      <bpmn:outgoing>e2</bpmn:outgoing>
      <bpmn:outgoing>e3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_nofunds6" name="Отказ: нет средств">
      <bpmn:incoming>e2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_cq" name="CadQuery установлен? (CADQUERY_PYTHON)">
      <bpmn:incoming>e3</bpmn:incoming>
      <bpmn:outgoing>e4</bpmn:outgoing>
      <bpmn:outgoing>e6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_cq_hint" name="Подсказка «pip install cadquery»">
      <bpmn:incoming>e4</bpmn:incoming>
      <bpmn:outgoing>e5</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_cq_hint" name="CAD недоступен">
      <bpmn:incoming>e5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_cad_vision" name="Описание детали (Claude Vision для фото / текст из /cad)">
      <bpmn:incoming>e6</bpmn:incoming>
      <bpmn:outgoing>e7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_cad_code" name="Claude: генерация CadQuery-кода (Python)">
      <bpmn:incoming>e7</bpmn:incoming>
      <bpmn:outgoing>e8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Task_exec" name="execFile CADQUERY_PYTHON, таймаут 60 c (tmp-каталог)">
      <bpmn:incoming>e8</bpmn:incoming>
      <bpmn:outgoing>e9</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="GW_files" name="STEP/STL созданы?">
      <bpmn:incoming>e9</bpmn:incoming>
      <bpmn:outgoing>e10</bpmn:outgoing>
      <bpmn:outgoing>e12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_cad_err" name="Ответ об ошибке генерации">
      <bpmn:incoming>e10</bpmn:incoming>
      <bpmn:outgoing>e11</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_cad_err" name="Ошибка показана">
      <bpmn:incoming>e11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Task_send_cad" name="Отправить STEP + STL">
      <bpmn:incoming>e12</bpmn:incoming>
      <bpmn:outgoing>e13</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:task id="Task_deduct6" name="deductBalance $0.02">
      <bpmn:incoming>e13</bpmn:incoming>
      <bpmn:outgoing>e14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_cleanup" name="Очистка tmp (rmSync)">
      <bpmn:incoming>e14</bpmn:incoming>
      <bpmn:outgoing>e15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_cad" name="CAD модель доставлена">
      <bpmn:incoming>e15</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Потоки P1 -->
    <bpmn:sequenceFlow id="a1" sourceRef="Start_text" targetRef="GW_empty" />
    <bpmn:sequenceFlow id="a2" name="да" sourceRef="GW_empty" targetRef="Task_hint" />
    <bpmn:sequenceFlow id="a3" sourceRef="Task_hint" targetRef="End_hint" />
    <bpmn:sequenceFlow id="a4" name="нет" sourceRef="GW_empty" targetRef="GW_bal1" />
    <bpmn:sequenceFlow id="a5" name="нет" sourceRef="GW_bal1" targetRef="Task_nofunds1" />
    <bpmn:sequenceFlow id="a6" sourceRef="Task_nofunds1" targetRef="End_nofunds1" />
    <bpmn:sequenceFlow id="a7" name="да" sourceRef="GW_bal1" targetRef="Task_progress" />
    <bpmn:sequenceFlow id="a8" sourceRef="Task_progress" targetRef="Task_t2i" />
    <bpmn:sequenceFlow id="a9" sourceRef="Task_t2i" targetRef="GW_ok1" />
    <bpmn:sequenceFlow id="a10" name="успех" sourceRef="GW_ok1" targetRef="Task_deduct1" />
    <bpmn:sequenceFlow id="a11" sourceRef="Task_deduct1" targetRef="Task_store1" />
    <bpmn:sequenceFlow id="a12" sourceRef="Task_store1" targetRef="Task_result1" />
    <bpmn:sequenceFlow id="a13" sourceRef="Task_result1" targetRef="GW_more" />
    <bpmn:sequenceFlow id="a14" name="нет" sourceRef="GW_more" targetRef="End_done1" />
    <bpmn:sequenceFlow id="a15" name="да — петля «Ещё вариант» (P4)" sourceRef="GW_more" targetRef="GW_bal1" />
    <bpmn:sequenceFlow id="a16" name="ошибка" sourceRef="GW_ok1" targetRef="GW_errtype" />
    <bpmn:sequenceFlow id="a17" name="timeout" sourceRef="GW_errtype" targetRef="Task_err_timeout" />
    <bpmn:sequenceFlow id="a18" name="safety | nsfw | content_filter" sourceRef="GW_errtype" targetRef="Task_err_nsfw" />
    <bpmn:sequenceFlow id="a19" name="rate | 429" sourceRef="GW_errtype" targetRef="Task_err_rate" />
    <bpmn:sequenceFlow id="a20" name="прочее" sourceRef="GW_errtype" targetRef="Task_err_other" />
    <bpmn:sequenceFlow id="a21" sourceRef="Task_err_timeout" targetRef="End_err1" />
    <bpmn:sequenceFlow id="a22" sourceRef="Task_err_nsfw" targetRef="End_err1" />
    <bpmn:sequenceFlow id="a23" sourceRef="Task_err_rate" targetRef="End_err1" />
    <bpmn:sequenceFlow id="a24" sourceRef="Task_err_other" targetRef="End_err1" />

    <!-- Потоки P2 -->
    <bpmn:sequenceFlow id="b1" sourceRef="Start_photo" targetRef="GW_pending" />
    <bpmn:sequenceFlow id="b2" name="да — это фото для face swap (P3)" sourceRef="GW_pending" targetRef="Catch_photo" />
    <bpmn:sequenceFlow id="b3" name="нет" sourceRef="GW_pending" targetRef="Task_getfile" />
    <bpmn:sequenceFlow id="b4" sourceRef="Task_getfile" targetRef="Task_upfal" />
    <bpmn:sequenceFlow id="b5" sourceRef="Task_upfal" targetRef="GW_key" />
    <bpmn:sequenceFlow id="b6" name="задан" sourceRef="GW_key" targetRef="Task_cv" />
    <bpmn:sequenceFlow id="b7" sourceRef="Task_cv" targetRef="GW_cv_ok" />
    <bpmn:sequenceFlow id="b8" name="да" sourceRef="GW_cv_ok" targetRef="Task_buttons" />
    <bpmn:sequenceFlow id="b9" name="ошибка — fallback" sourceRef="GW_cv_ok" targetRef="Task_florence" />
    <bpmn:sequenceFlow id="b10" name="нет ключа" sourceRef="GW_key" targetRef="Task_florence" />
    <bpmn:sequenceFlow id="b11" sourceRef="Task_florence" targetRef="Task_buttons" />
    <bpmn:sequenceFlow id="b12" sourceRef="Task_buttons" targetRef="End_p2" />

    <!-- Потоки P3 -->
    <bpmn:sequenceFlow id="c1" sourceRef="Start_fs" targetRef="GW_prompt" />
    <bpmn:sequenceFlow id="c2" name="нет — истёк" sourceRef="GW_prompt" targetRef="End_expired" />
    <bpmn:sequenceFlow id="c3" name="да" sourceRef="GW_prompt" targetRef="Task_askphoto" />
    <bpmn:sequenceFlow id="c4" sourceRef="Task_askphoto" targetRef="Catch_photo" />
    <bpmn:sequenceFlow id="c5" sourceRef="Catch_photo" targetRef="Task_hair" />
    <bpmn:sequenceFlow id="c6" sourceRef="Task_hair" targetRef="Task_params" />
    <bpmn:sequenceFlow id="c7" sourceRef="Task_params" targetRef="Catch_fs" />
    <bpmn:sequenceFlow id="c8" sourceRef="Catch_fs" targetRef="GW_chosen" />
    <bpmn:sequenceFlow id="c9" name="нет — обновить клавиатуру" sourceRef="GW_chosen" targetRef="Task_params" />
    <bpmn:sequenceFlow id="c10" name="да" sourceRef="GW_chosen" targetRef="GW_bal3" />
    <bpmn:sequenceFlow id="c11" name="нет" sourceRef="GW_bal3" targetRef="End_nofunds3" />
    <bpmn:sequenceFlow id="c12" name="да" sourceRef="GW_bal3" targetRef="Task_edit" />
    <bpmn:sequenceFlow id="c13" sourceRef="Task_edit" targetRef="GW_ok3" />
    <bpmn:sequenceFlow id="c14" name="успех" sourceRef="GW_ok3" targetRef="Task_deduct3" />
    <bpmn:sequenceFlow id="c15" sourceRef="Task_deduct3" targetRef="Task_result3" />
    <bpmn:sequenceFlow id="c16" sourceRef="Task_result3" targetRef="End_fs" />
    <bpmn:sequenceFlow id="c17" name="ошибка" sourceRef="GW_ok3" targetRef="Task_reset" />
    <bpmn:sequenceFlow id="c18" sourceRef="Task_reset" targetRef="End_fs_err" />

    <!-- Потоки P5 -->
    <bpmn:sequenceFlow id="d1" sourceRef="Start_3d" targetRef="Task_menu3d" />
    <bpmn:sequenceFlow id="d2" sourceRef="Task_menu3d" targetRef="Catch_q" />
    <bpmn:sequenceFlow id="d3" sourceRef="Catch_q" targetRef="GW_bal5" />
    <bpmn:sequenceFlow id="d4" name="нет" sourceRef="GW_bal5" targetRef="End_nofunds5" />
    <bpmn:sequenceFlow id="d5" name="да" sourceRef="GW_bal5" targetRef="Task_rembg" />
    <bpmn:sequenceFlow id="d6" sourceRef="Task_rembg" targetRef="Task_gen3d" />
    <bpmn:sequenceFlow id="d7" sourceRef="Task_gen3d" targetRef="Task_deduct5" />
    <bpmn:sequenceFlow id="d8" sourceRef="Task_deduct5" targetRef="Task_glb" />
    <bpmn:sequenceFlow id="d9" sourceRef="Task_glb" targetRef="End_3d" />

    <!-- Потоки P6 -->
    <bpmn:sequenceFlow id="e1" sourceRef="Start_cad" targetRef="GW_bal6" />
    <bpmn:sequenceFlow id="e2" name="нет" sourceRef="GW_bal6" targetRef="End_nofunds6" />
    <bpmn:sequenceFlow id="e3" name="да" sourceRef="GW_bal6" targetRef="GW_cq" />
    <bpmn:sequenceFlow id="e4" name="нет" sourceRef="GW_cq" targetRef="Task_cq_hint" />
    <bpmn:sequenceFlow id="e5" sourceRef="Task_cq_hint" targetRef="End_cq_hint" />
    <bpmn:sequenceFlow id="e6" name="да" sourceRef="GW_cq" targetRef="Task_cad_vision" />
    <bpmn:sequenceFlow id="e7" sourceRef="Task_cad_vision" targetRef="Task_cad_code" />
    <bpmn:sequenceFlow id="e8" sourceRef="Task_cad_code" targetRef="Task_exec" />
    <bpmn:sequenceFlow id="e9" sourceRef="Task_exec" targetRef="GW_files" />
    <bpmn:sequenceFlow id="e10" name="нет" sourceRef="GW_files" targetRef="Task_cad_err" />
    <bpmn:sequenceFlow id="e11" sourceRef="Task_cad_err" targetRef="End_cad_err" />
    <bpmn:sequenceFlow id="e12" name="да" sourceRef="GW_files" targetRef="Task_send_cad" />
    <bpmn:sequenceFlow id="e13" sourceRef="Task_send_cad" targetRef="Task_deduct6" />
    <bpmn:sequenceFlow id="e14" sourceRef="Task_deduct6" targetRef="Task_cleanup" />
    <bpmn:sequenceFlow id="e15" sourceRef="Task_cleanup" targetRef="End_cad" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="Diagram_seedream">
    <bpmndi:BPMNPlane id="Plane_seedream" bpmnElement="Collab_seedream">

      <!-- Пулы и дорожки -->
